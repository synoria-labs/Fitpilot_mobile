APP_ENV=development
EXPO_PUBLIC_NUTRITION_API_URL=http://localhost:3000/v1
EXPO_PUBLIC_TRAINING_API_URL=http://localhost:8010/api
# Puedes sobreescribir esta URL en local si necesitas probar otro bridge.
EXPO_PUBLIC_TURNSTILE_BRIDGE_URL=https://pro.fitpilot.fit/turnstile/mobile
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_PRIVACY_URL=
