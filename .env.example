# Si corres la app en un dispositivo fisico, reemplaza localhost por la IP LAN del host.
# Ejemplo:
# EXPO_PUBLIC_NUTRITION_API_URL=http://192.168.1.20:3000/v1
# EXPO_PUBLIC_TRAINING_API_URL=http://192.168.1.20:8010/api
